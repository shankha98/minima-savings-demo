# Minima savings demo — environment.
# Copy this file to `.env` and fill in real values. `.env` is gitignored; never commit keys.

# Minima API (hosted). Override for staging / self-host.
MINIMA_URL=https://api.minima.sh

# Mubit API key — must be a REAL prod key (format: mbt_<instance>_<key_id>_<secret>).
# A local-dev key (mbt_local_...) routes to a non-existent prod tenant and 503s,
# which makes feedback fail silently. Rotate this key after you finish demoing.
MUBIT_API_KEY=mbt_<instance>_<key_id>_<secret>

# Anthropic key — only needed for `make run-live` (real model calls).
ANTHROPIC_API_KEY=sk-ant-...

# How many times to repeat the 4-task batch (4 -> 16 calls).
MINIMA_DEMO_REPEAT=4

# Optional: pin a namespace (otherwise a fresh demo-<rand> ledger is used each run).
# MINIMA_DEMO_NS=demo-myrun

# Optional: force live mode here instead of using `make run-live`.
# MINIMA_DEMO_LIVE=1
